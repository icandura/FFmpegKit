<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- ffmpeg 可执行文件完整路径 -->
    <add key="FFmpegPath" value="" />
    <!-- 默认 GPU 加速器：none / nvenc / amf / qsv -->
    <add key="DefaultGPU" value="none" />
    <!-- 是否自动检测硬件（未来扩展用） -->
    <add key="AutoDetectGPU" value="false" />
  </appSettings>
</configuration>